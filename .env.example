# ─── Client (Vite) — public, shipped in browser bundle ────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Cloudflare Worker that proxies OpenRouter calls. Deploy with:
#   cd worker && npm install && wrangler secret put OPENROUTER_KEY && wrangler deploy
# Then set this URL to the deployed worker origin (no trailing slash).
VITE_AI_WORKER_URL=http://localhost:8787

# ─── Seed script (seed-questions.mjs) — server-side only, never bundled ──────
# Match these to your Firebase project. SEED_EMAIL must be an existing
# SuperAdmin user in Firebase Auth.
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
SEED_EMAIL=superadmin@example.com
SEED_PASSWORD=replace_with_strong_password
